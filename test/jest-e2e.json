{
  "moduleFileExtensions": ["js", "json", "ts", "mjs"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest",
    "^.+\\.mjs$": "ts-jest"
  },
  "moduleNameMapper": {
    "^(\\.{1,2}/.*)\\.js$": "$1"
  },
  "transformIgnorePatterns": [
    "node_modules/(?!(better-auth|@better-auth|@noble|arcjet|@arcjet/nest|@arcjet/protocol|@thallesp/nestjs-better-auth))"
  ]
}
